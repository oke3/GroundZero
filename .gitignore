# Git Ignore for GroundZero — Thin Public Repo
# Only README.md and docs/ are tracked. Everything else is local-only.

# OS files
.DS_Store
Thumbs.db

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Local env/logs
.env
*.log
logs/
tmp/

# Build tooling & project scaffold (local dev only)
package.json
package-lock.json
astro.config.mjs
tailwind.config.*
postcss.config.js
tsconfig.json
.astro/

# Astro source — not shipped to public repo
src/

# Public assets source
public/

# OpenCode workspace config (local agent environment only)
.opencode/
.specify/

# Canonical Data — full directory lives locally; public subset is in docs/
data/

# Internal automation — scripts don't ship to the public surface
scripts/
update_data.js

# CI/CD workflows — run via private runner or local execution only
.github/

# Internal documentation (not exposed to public)
*.md
!README.md

# Serve symlink (created by npm run serve)
GroundZero
